<?xml version="1.0" encoding="UTF-8"?>
<!--
  TIBCO BusinessWorks 5.13
  Process: KafkaConsumer
  Projeto: BWKAFKACONNECT
  Pasta: SharedResources

  Como usar:
    1. Copie este arquivo para: BWKAFKACONNECT/SharedResources/KafkaConsumer.process
    2. Abra o TIBCO Designer
    3. O processo aparece em SharedResources/KafkaConsumer
    4. Outros processos chamam via "Call Process"
-->
<repository version="3.0.0" xmlns="http://www.tibco.com/xmlns/repo/types/2002">
  <process-definition
    xmlns:pd="http://xmlns.tibco.com/bw/process/2003"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:tib="http://www.tibco.com/bw/xslt/custom-functions"
    xmlns:pfx="http://www.tibco.com/pe/EngineTypes">

    <pd:name>SharedResources/KafkaConsumer</pd:name>
    <pd:startName>Start</pd:startName>
    <pd:returnBindings/>

    <!-- ═══════════════════════════════════════════════
         SCHEMA DE INPUT DO PROCESSO
    ═══════════════════════════════════════════════ -->
    <pd:startNamespace>
      <xsd:schema
        targetNamespace="http://www.tibco.com/xmlns/bwkafka/consumer/input"
        xmlns:tns="http://www.tibco.com/xmlns/bwkafka/consumer/input"
        elementFormDefault="qualified">

        <xsd:element name="KafkaConsumeInput">
          <xsd:complexType>
            <xsd:sequence>

              <!-- Tópico a consumir -->
              <xsd:element name="topic"       type="xsd:string"  minOccurs="1" maxOccurs="1"/>

              <!-- Consumer Group ID -->
              <xsd:element name="groupId"     type="xsd:string"  minOccurs="1" maxOccurs="1"/>

              <!-- Máximo de mensagens por poll (default: 10) -->
              <xsd:element name="maxMessages" type="xsd:integer" minOccurs="0" maxOccurs="1"/>

              <!-- Timeout do poll em ms (default: 5000) -->
              <xsd:element name="pollTimeout" type="xsd:long"    minOccurs="0" maxOccurs="1"/>

              <!-- Commit automático de offset (default: true) -->
              <xsd:element name="autoCommit"  type="xsd:boolean" minOccurs="0" maxOccurs="1"/>

            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>

      </xsd:schema>
    </pd:startNamespace>

    <!-- ═══════════════════════════════════════════════
         SCHEMA DE OUTPUT DO PROCESSO
    ═══════════════════════════════════════════════ -->
    <pd:endName>End</pd:endName>
    <pd:endNamespace>
      <xsd:schema
        targetNamespace="http://www.tibco.com/xmlns/bwkafka/consumer/output"
        xmlns:tns="http://www.tibco.com/xmlns/bwkafka/consumer/output"
        elementFormDefault="qualified">

        <xsd:element name="KafkaConsumeOutput">
          <xsd:complexType>
            <xsd:sequence>

              <xsd:element name="status"       type="xsd:string"  minOccurs="1"/>
              <xsd:element name="totalMessages" type="xsd:integer" minOccurs="0"/>
              <xsd:element name="errorMessage"  type="xsd:string"  minOccurs="0"/>

              <xsd:element name="messages" minOccurs="0" maxOccurs="1">
                <xsd:complexType>
                  <xsd:sequence>
                    <xsd:element name="message" minOccurs="0" maxOccurs="unbounded">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element name="topic"     type="xsd:string"  minOccurs="1"/>
                          <xsd:element name="partition" type="xsd:integer" minOccurs="1"/>
                          <xsd:element name="offset"    type="xsd:long"    minOccurs="1"/>
                          <xsd:element name="key"       type="xsd:string"  minOccurs="0"/>
                          <xsd:element name="value"     type="xsd:string"  minOccurs="1"/>
                          <xsd:element name="timestamp" type="xsd:long"    minOccurs="0"/>
                          <xsd:element name="headers" minOccurs="0" maxOccurs="1">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="header" minOccurs="0" maxOccurs="unbounded">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="key"   type="xsd:string" minOccurs="1"/>
                                      <xsd:element name="value" type="xsd:string" minOccurs="1"/>
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                        </xsd:sequence>
                      </xsd:complexType>
                    </xsd:element>
                  </xsd:sequence>
                </xsd:complexType>
              </xsd:element>

            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>

      </xsd:schema>
    </pd:endNamespace>

    <!-- ═══════════════════════════════════════════════
         ATIVIDADES DO PROCESSO
    ═══════════════════════════════════════════════ -->
    <pd:activities>

      <!-- ─────────────────────────────
           ATIVIDADE 1: START
      ───────────────────────────── -->
      <pd:activity name="Start">
        <pd:type>com.tibco.pe.core.StartEventActivity</pd:type>
        <pd:resourceType>ae.activities.StartEventActivity</pd:resourceType>
        <pd:x>80</pd:x>
        <pd:y>150</pd:y>
        <config/>
        <pd:outputBindings>
          <xsl:template name="Start">
            <KafkaConsumeInput xmlns="http://www.tibco.com/xmlns/bwkafka/consumer/input"/>
          </xsl:template>
        </pd:outputBindings>
      </pd:activity>

      <!-- ─────────────────────────────
           ATIVIDADE 2: Java Activity — KafkaConsumeService
           Chama o JAR que faz o poll no Kafka
      ───────────────────────────── -->
      <pd:activity name="KafkaConsumeMessage">
        <pd:type>com.tibco.plugin.java.JavaActivity</pd:type>
        <pd:resourceType>ae.activities.JavaActivity</pd:resourceType>
        <pd:x>280</pd:x>
        <pd:y>150</pd:y>
        <config>
          <!--
            ATENÇÃO: Preencher no Designer após copiar:
            Class Name:  com.empresa.kafka.bw.service.KafkaConsumeService
            Method Name: consumeFromBW
          -->
          <pd:className>com.empresa.kafka.bw.service.KafkaConsumeService</pd:className>
          <pd:methodName>consumeFromBW</pd:methodName>
        </config>

        <pd:inputBindings>
          <xsl:template name="KafkaConsumeMessage">
            <JavaInput>
              <!-- Conexão — das Module Properties -->
              <bootstrapServers>
                <xsl:value-of select="$_globalVariables/GlobalVariables/KafkaBootstrapServers"/>
              </bootstrapServers>
              <authUsername>
                <xsl:value-of select="$_globalVariables/GlobalVariables/KafkaUsername"/>
              </authUsername>
              <authPassword>
                <xsl:value-of select="$_globalVariables/GlobalVariables/KafkaPassword"/>
              </authPassword>
              <!-- Parâmetros do Consumer — vêm do input -->
              <topic>
                <xsl:value-of select="$Start/topic"/>
              </topic>
              <groupId>
                <xsl:value-of select="$Start/groupId"/>
              </groupId>
              <maxMessages>
                <xsl:choose>
                  <xsl:when test="$Start/maxMessages != ''">
                    <xsl:value-of select="$Start/maxMessages"/>
                  </xsl:when>
                  <xsl:otherwise>10</xsl:otherwise>
                </xsl:choose>
              </maxMessages>
              <pollTimeout>
                <xsl:choose>
                  <xsl:when test="$Start/pollTimeout != ''">
                    <xsl:value-of select="$Start/pollTimeout"/>
                  </xsl:when>
                  <xsl:otherwise>5000</xsl:otherwise>
                </xsl:choose>
              </pollTimeout>
              <autoCommit>
                <xsl:choose>
                  <xsl:when test="$Start/autoCommit != ''">
                    <xsl:value-of select="$Start/autoCommit"/>
                  </xsl:when>
                  <xsl:otherwise>true</xsl:otherwise>
                </xsl:choose>
              </autoCommit>
            </JavaInput>
          </xsl:template>
        </pd:inputBindings>

      </pd:activity>

      <!-- ─────────────────────────────
           ATIVIDADE 3: Mapper — Monta output SUCCESS
      ───────────────────────────── -->
      <pd:activity name="MapOutputSuccess">
        <pd:type>com.tibco.plugin.mapper.MapperActivity</pd:type>
        <pd:resourceType>ae.activities.MapperActivity</pd:resourceType>
        <pd:x>480</pd:x>
        <pd:y>100</pd:y>
        <config/>
        <pd:inputBindings>
          <xsl:template name="MapOutputSuccess">
            <KafkaConsumeOutput xmlns="http://www.tibco.com/xmlns/bwkafka/consumer/output">
              <status>SUCCESS</status>
              <totalMessages>
                <xsl:value-of select="count($KafkaConsumeMessage/messages/message)"/>
              </totalMessages>
              <errorMessage></errorMessage>
              <messages>
                <xsl:for-each select="$KafkaConsumeMessage/messages/message">
                  <message>
                    <topic><xsl:value-of select="topic"/></topic>
                    <partition><xsl:value-of select="partition"/></partition>
                    <offset><xsl:value-of select="offset"/></offset>
                    <key><xsl:value-of select="key"/></key>
                    <value><xsl:value-of select="value"/></value>
                    <timestamp><xsl:value-of select="timestamp"/></timestamp>
                    <headers>
                      <xsl:for-each select="headers/header">
                        <header>
                          <key><xsl:value-of select="key"/></key>
                          <value><xsl:value-of select="value"/></value>
                        </header>
                      </xsl:for-each>
                    </headers>
                  </message>
                </xsl:for-each>
              </messages>
            </KafkaConsumeOutput>
          </xsl:template>
        </pd:inputBindings>
      </pd:activity>

      <!-- ─────────────────────────────
           ATIVIDADE 4: Mapper — Monta output ERROR
      ───────────────────────────── -->
      <pd:activity name="MapOutputError">
        <pd:type>com.tibco.plugin.mapper.MapperActivity</pd:type>
        <pd:resourceType>ae.activities.MapperActivity</pd:resourceType>
        <pd:x>480</pd:x>
        <pd:y>250</pd:y>
        <config/>
        <pd:inputBindings>
          <xsl:template name="MapOutputError">
            <KafkaConsumeOutput xmlns="http://www.tibco.com/xmlns/bwkafka/consumer/output">
              <status>ERROR</status>
              <totalMessages>0</totalMessages>
              <errorMessage>
                <xsl:value-of select="$_error/pfx:ErrorReport/pfx:Msg"/>
              </errorMessage>
              <messages/>
            </KafkaConsumeOutput>
          </xsl:template>
        </pd:inputBindings>
      </pd:activity>

      <!-- ─────────────────────────────
           ATIVIDADE 5: END
      ───────────────────────────── -->
      <pd:activity name="End">
        <pd:type>com.tibco.pe.core.EndActivity</pd:type>
        <pd:resourceType>ae.activities.EndActivity</pd:resourceType>
        <pd:x>680</pd:x>
        <pd:y>150</pd:y>
        <config/>
        <pd:inputBindings>
          <xsl:template name="End">
            <KafkaConsumeOutput xmlns="http://www.tibco.com/xmlns/bwkafka/consumer/output">
              <xsl:choose>
                <xsl:when test="$MapOutputSuccess">
                  <xsl:copy-of select="$MapOutputSuccess/*"/>
                </xsl:when>
                <xsl:otherwise>
                  <xsl:copy-of select="$MapOutputError/*"/>
                </xsl:otherwise>
              </xsl:choose>
            </KafkaConsumeOutput>
          </xsl:template>
        </pd:inputBindings>
      </pd:activity>

    </pd:activities>

    <!-- ═══════════════════════════════════════════════
         TRANSIÇÕES
    ═══════════════════════════════════════════════ -->
    <pd:transitions>

      <pd:transition>
        <pd:from>Start</pd:from>
        <pd:to>KafkaConsumeMessage</pd:to>
        <pd:lineType>Default</pd:lineType>
      </pd:transition>

      <pd:transition>
        <pd:from>KafkaConsumeMessage</pd:from>
        <pd:to>MapOutputSuccess</pd:to>
        <pd:lineType>Default</pd:lineType>
      </pd:transition>

      <pd:transition>
        <pd:from>MapOutputSuccess</pd:from>
        <pd:to>End</pd:to>
        <pd:lineType>Default</pd:lineType>
      </pd:transition>

      <pd:transition>
        <pd:from>KafkaConsumeMessage</pd:from>
        <pd:to>MapOutputError</pd:to>
        <pd:lineType>ExceptionHandler</pd:lineType>
        <pd:conditionType>error</pd:conditionType>
      </pd:transition>

      <pd:transition>
        <pd:from>MapOutputError</pd:from>
        <pd:to>End</pd:to>
        <pd:lineType>Default</pd:lineType>
      </pd:transition>

    </pd:transitions>

  </process-definition>
</repository>
